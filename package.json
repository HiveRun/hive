{
  "name": "hive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "tsdown": "^0.15.5",
      "@opencode-ai/sdk": "^1.2.14"
    }
  },
  "scripts": {
    "setup": "bun install && bun run ruler:apply && bun run setup:desktop-e2e && bun run config:generate && bun run db:migrate && bun run setup:server-elixir",
    "setup:desktop-e2e": "./scripts/dev/setup-desktop-e2e.sh",
    "check": "bun run check:commit",
    "check:commit": "bun run check:config && bun run check:staged && bun run check:secrets && bun run check:audit && biome check --no-errors-on-unmatched --files-ignore-unknown=true && bash scripts/check/run-heavy-checks.sh",
    "check:distribution": "bun run scripts/distribution/check-distribution.ts",
    "check:push": "bun run check:commit",
    "test": "turbo test --ui=stream --force --concurrency=100%",
    "test:run": "turbo test:run --ui=stream --force --concurrency=100%",
    "test:e2e": "bun run --cwd apps/e2e test:e2e",
    "test:e2e:tune": "bun run --cwd apps/e2e test:e2e:tune",
    "test:e2e:headed": "bun run --cwd apps/e2e test:e2e:headed",
    "test:e2e:spec": "bun run --cwd apps/e2e test:e2e -- --spec",
    "test:e2e:report": "bun run --cwd apps/e2e report:e2e",
    "test:e2e:report:open": "bun run --cwd apps/e2e report:e2e:open",
    "test:e2e:report:serve": "bun run --cwd apps/e2e report:e2e:serve",
    "test:e2e:desktop": "bun run --cwd apps/e2e-desktop test:e2e",
    "test:e2e:desktop:spec": "bun run --cwd apps/e2e-desktop test:e2e -- --spec",
    "ab:shot": "bash scripts/agent-browser.sh shot",
    "ab:record:start": "bash scripts/agent-browser.sh record-start",
    "ab:record:stop": "bash scripts/agent-browser.sh record-stop",
    "ab:latest": "bash scripts/agent-browser.sh latest",
    "ab:latest:video": "bash scripts/agent-browser.sh latest-video",
    "ab:view": "bash scripts/agent-browser.sh view",
    "ab:view:video": "bash scripts/agent-browser.sh view-video",
    "check:config": "bun run config:generate && bunx biome check --write hive.config.json hive.config.schema.json && git diff --exit-code hive.config.json hive.config.schema.json",
    "check:biome": "biome check --write .",
    "check:staged": "lint-staged --allow-empty",
    "check:secrets": "./scripts/check-secrets.sh",
    "check:audit": "bun audit --audit-level high || echo '⚠️  Security audit found issues (see above)'",
    "ruler:apply": "cp README.md .ruler/prompts/README.md && bunx @intellectronica/ruler@latest apply --local-only && biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "dev": "bash scripts/dev/run-web-and-elixir.sh",
    "dev:ports": "bun run scripts/dev/dev-ports.ts",
    "dev:turbo": "turbo run dev --filter=web...",
    "build": "turbo build --concurrency=100%",
    "build:installer": "bun run scripts/distribution/build.ts",
    "local:install": "bun run scripts/distribution/local-install.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "check:release-version": "bun run scripts/release/check-release-version.ts",
    "release:prepare": "bun run scripts/release/prepare-release.ts",
    "release:tag": "bun run scripts/release/tag-version.ts",
    "check-types": "turbo check-types --ui=stream --force --concurrency=100%",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "bun run dev:server-elixir",
    "dev:server-elixir": "bash -lc 'mise x -C apps/hive_server_elixir -- mix ecto.migrate && exec mise x -C apps/hive_server_elixir -- iex -S mix phx.server'",
    "setup:server-elixir": "mise x -C apps/hive_server_elixir -- mix setup",
    "test:server-elixir": "MIX_ENV=test mise x -C apps/hive_server_elixir -- mix do compile --warnings-as-errors + test --warnings-as-errors",
    "check:server-elixir": "mise x -C apps/hive_server_elixir -- mix ash.codegen --check && mise x -C apps/hive_server_elixir -- mix format --check-formatted && mise x -C apps/hive_server_elixir -- mix compile --warnings-as-errors && mise x -C apps/hive_server_elixir -- mix xref graph --format cycles --label compile-connected --fail-above 0",
    "dev:desktop": "bun run --cwd apps/desktop-electron start",
    "build:desktop": "bun run --cwd apps/desktop-electron package",
    "config:generate": "bun scripts/dev/generate-config.ts && bun scripts/dev/generate-config-schema.ts",
    "db:local": "DATABASE_PATH=local.db mise x -C apps/hive_server_elixir -- mix ecto.migrate",
    "db:push": "mise x -C apps/hive_server_elixir -- mix ecto.migrate",
    "db:studio": "bash -lc 'printf \"Use a SQLite browser against %s\\n\" \"${DATABASE_PATH:-apps/hive_server_elixir/hive_server_elixir_dev.db}\"'",
    "db:generate": "mise x -C apps/hive_server_elixir -- mix ash.codegen",
    "db:migrate": "mise x -C apps/hive_server_elixir -- mix ecto.migrate",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/bun": "^1.2.6",
    "@changesets/cli": "^2.29.7",
    "husky": "^9.1.7",
    "typescript": "catalog:",
    "lint-staged": "^16.1.2",
    "tsdown": "^0.15.5",
    "turbo": "^2.5.4",
    "ultracite": "6.0.1"
  },
  "packageManager": "bun@1.3.5",
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": [
      "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ],
    "**/*.json": [
      "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  }
}
